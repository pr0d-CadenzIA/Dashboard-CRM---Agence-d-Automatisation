# ============================================================
# CRM Dashboard — Variables d'environnement (template)
# Copier ce fichier en .env et renseigner les valeurs réelles.
# Le fichier .env ne doit JAMAIS être commité.
# ============================================================

# --- MVP (Phase 1) ---
# Aucune variable requise : architecture 100% frontend, données en mémoire.

# --- V2 / SaaS (Phase 3) — Supabase ---
# À activer quand le backend Supabase remplace le parsing CSV local.
# VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGci...

# --- Optionnel : mode debug Vite ---
# VITE_DEBUG=false
